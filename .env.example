# Local development defaults. For Docker Compose you can switch
# APP_DB_USERNAME / APP_DB_PASSWORD to the container defaults below.
APP_DB_URL=jdbc:mysql://localhost:3306/yinyue_db?useSSL=false&serverTimezone=UTC&characterEncoding=utf8&allowPublicKeyRetrieval=true&allowLoadLocalInfile=false&createDatabaseIfNotExist=true
APP_DB_USERNAME=root
APP_DB_PASSWORD=
# APP_DB_USERNAME=yinyue
# APP_DB_PASSWORD=yinyue

APP_LLM_API_KEY=
APP_LLM_BASE_URL=https://api.openai.com
APP_LLM_MODEL=
APP_LLM_DEFAULT_MODEL=gpt-5.4-mini
# Legacy DashScope/Qwen vars are still supported when needed:
APP_QWEN_API_KEY=
APP_QWEN_BASE_URL=
APP_QWEN_LLM_MODEL=
APP_AUDD_API_KEY=
APP_SD_ENDPOINT=http://127.0.0.1:7860

APP_API_TOKEN=replace-with-a-strong-token
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_SECURITY_ENABLED=false
APP_RATE_LIMIT_ENABLED=false
APP_RATE_LIMIT_PER_MINUTE=60

APP_PYTHON_COMMAND=python
APP_NETEASE_SCRIPT_PATH=./netease_parser.py
APP_NETEASE_TIMEOUT_SECONDS=15
APP_ANALYSIS_PYTHON_COMMAND=.venv-audio/Scripts/python.exe
APP_ANALYSIS_SCRIPT_PATH=./scripts/analyze_audio.py
APP_ANALYSIS_PROVIDER=auto
APP_ANALYSIS_TIMEOUT_SECONDS=60

APP_SEPARATION_PYTHON_COMMAND=.venv-audio/Scripts/python.exe
APP_SEPARATION_SCRIPT_PATH=./scripts/separate_audio.py
APP_SEPARATION_OUTPUT_ROOT=./runtime/separated
APP_SEPARATION_TIMEOUT_SECONDS=180
APP_SEPARATION_MODEL=htdemucs
APP_SEPARATION_DEVICE=auto

APP_SEMANTIC_PYTHON_COMMAND=.venv-audio/Scripts/python.exe
APP_SEMANTIC_SCRIPT_PATH=./scripts/extract_music_semantics.py
APP_SEMANTIC_TIMEOUT_SECONDS=180
APP_SEMANTIC_MODEL_ID=m-a-p/MERT-v1-95M
APP_SEMANTIC_DEVICE=auto
APP_SEMANTIC_MAX_SECONDS=30

# Optional Docker Compose ports
APP_SERVER_PORT=8081
MYSQL_PORT=3307
REDIS_PORT=6379
BACKEND_PORT=8081
